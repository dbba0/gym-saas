cat > .gitignore <<'EOF'
# dependencies
node_modules/

# next / build
.next/
dist/
build/
out/

# expo
.expo/
.expo-shared/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env
.env
.env.local
.env.*.local
!.env.example

# macOS
.DS_Store

# typescript
*.tsbuildinfo

# coverage
coverage/

# misc
.tmp/
.cache/
EOF