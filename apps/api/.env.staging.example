PORT=4000
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?schema=public
JWT_SECRET=<long-random-secret>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGIN=https://admin-staging.your-domain.com,https://staging.your-domain.com
API_PUBLIC_BASE_URL=https://api-staging.your-domain.com
PAYMENT_PROVIDER=PAYDUNYA
PAYMENT_CURRENCY=XOF
PAYDUNYA_MODE=sandbox
PAYDUNYA_MASTER_KEY=<paydunya-master-key>
PAYDUNYA_PRIVATE_KEY=<paydunya-private-key>
PAYDUNYA_TOKEN=<paydunya-token>
PAYDUNYA_CREATE_URL=
PAYDUNYA_CONFIRM_BASE_URL=
PAYDUNYA_CALLBACK_URL=https://api-staging.your-domain.com/api/payments/webhooks/paydunya
PAYDUNYA_RETURN_URL=https://admin-staging.your-domain.com/payments/success
PAYDUNYA_CANCEL_URL=https://admin-staging.your-domain.com/payments/cancel
PAYDUNYA_WEBHOOK_SECRET=<paydunya-webhook-secret>
PAYDUNYA_WEBHOOK_TOLERANCE_SECONDS=300
