generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COACH
  MEMBER
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  FREE_MONEY
  MOBILE_MONEY
  CARD
  CASH
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PENDING
}

enum AttendanceSource {
  QR
  MANUAL
}

enum ReservationStatus {
  RESERVED
  CANCELED
  CHECKED_IN
  NO_SHOW
}

model Gym {
  id          String         @id @default(uuid())
  name        String
  address     String?
  phone       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  users       User[]
  members     Member[]
  coaches     Coach[]
  subscriptions Subscription[]
  programs    Program[]
  classSessions ClassSession[]

  @@map("gyms")
}

model User {
  id            String   @id @default(uuid())
  gymId         String?
  role          Role
  email         String   @unique
  passwordHash  String
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  gym           Gym?     @relation(fields: [gymId], references: [id])
  member        Member?
  coach         Coach?
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id                 String    @id @default(uuid())
  userId             String
  tokenHash          String    @unique
  expiresAt          DateTime
  createdAt          DateTime  @default(now())
  revokedAt          DateTime?
  replacedByTokenHash String?
  createdByIp        String?
  userAgent          String?

  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Member {
  id            String   @id @default(uuid())
  gymId         String
  userId        String?  @unique
  subscriptionId String?
  coachId       String?
  qrToken       String   @unique
  joinDate      DateTime @default(now())
  firstName     String
  lastName      String
  phone         String?
  email         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gym           Gym      @relation(fields: [gymId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  coach         Coach?   @relation(fields: [coachId], references: [id])

  programs      Program[]
  payments      Payment[]
  attendance    Attendance[]
  subscriptionsHistory MemberSubscription[]
  progressEntries ProgressEntry[]
  reservations  ClassReservation[]

  @@index([gymId])
  @@index([coachId])
  @@map("members")
}

model Coach {
  id          String   @id @default(uuid())
  gymId       String
  userId      String?  @unique
  name        String
  speciality  String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym         Gym      @relation(fields: [gymId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  members     Member[]
  programs    Program[]
  classSessions ClassSession[]

  @@index([gymId])
  @@map("coaches")
}

model Subscription {
  id            String   @id @default(uuid())
  gymId         String
  name          String
  priceCents    Int
  durationMonths Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gym           Gym      @relation(fields: [gymId], references: [id])
  members       Member[]
  payments      Payment[]
  memberSubscriptions MemberSubscription[]

  @@index([gymId])
  @@map("subscriptions")
}

model MemberSubscription {
  id             String   @id @default(uuid())
  memberId       String
  subscriptionId String
  startDate      DateTime
  endDate        DateTime
  status         SubscriptionStatus @default(ACTIVE)
  createdAt      DateTime @default(now())

  member         Member  @relation(fields: [memberId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([memberId])
  @@index([subscriptionId])
  @@map("member_subscriptions")
}

model Program {
  id          String   @id @default(uuid())
  gymId       String
  coachId     String?
  memberId    String?
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym         Gym      @relation(fields: [gymId], references: [id])
  coach       Coach?   @relation(fields: [coachId], references: [id])
  member      Member?  @relation(fields: [memberId], references: [id])
  exercises   Exercise[]

  @@index([gymId])
  @@index([coachId])
  @@index([memberId])
  @@map("programs")
}

model Exercise {
  id          String   @id @default(uuid())
  programId   String
  name        String
  sets        Int
  reps        Int
  restSeconds Int

  program     Program  @relation(fields: [programId], references: [id])

  @@index([programId])
  @@map("exercises")
}

model Payment {
  id             String   @id @default(uuid())
  memberId       String
  subscriptionId String?
  amountCents    Int
  method         PaymentMethod
  paidAt         DateTime @default(now())
  status         String   @default("PAID")
  provider       String   @default("INTERNAL")
  providerReference String? @unique
  providerPaymentId String?
  checkoutUrl    String?
  failureReason  String?
  providerPayload Json?
  confirmedAt    DateTime?
  webhookEvents  PaymentWebhookEvent[]

  member         Member  @relation(fields: [memberId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([memberId])
  @@index([subscriptionId])
  @@map("payments")
}

model PaymentWebhookEvent {
  id                String   @id @default(uuid())
  provider          String
  eventKey          String
  providerReference String?
  status            String?
  payloadHash       String
  rawPayload        Json?
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  paymentId         String?

  payment           Payment? @relation(fields: [paymentId], references: [id])

  @@unique([provider, eventKey])
  @@index([providerReference])
  @@index([paymentId])
  @@map("payment_webhook_events")
}

model Attendance {
  id              String   @id @default(uuid())
  memberId        String
  checkedInAt     DateTime @default(now())
  source          AttendanceSource @default(QR)
  scannedByUserId String?

  member          Member  @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("attendance")
}

model ProgressEntry {
  id         String   @id @default(uuid())
  memberId   String
  entryDate  DateTime @default(now())
  weightKg   Float?
  bodyFatPct Float?
  notes      String?

  member     Member   @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("progress_entries")
}

model ClassSession {
  id        String   @id @default(uuid())
  gymId     String
  coachId   String?
  title     String
  startsAt  DateTime
  endsAt    DateTime
  capacity  Int
  createdAt DateTime @default(now())

  gym       Gym      @relation(fields: [gymId], references: [id])
  coach     Coach?   @relation(fields: [coachId], references: [id])
  reservations ClassReservation[]

  @@index([gymId])
  @@index([coachId])
  @@map("class_sessions")
}

model ClassReservation {
  id        String   @id @default(uuid())
  classId   String
  memberId  String
  status    ReservationStatus @default(RESERVED)
  createdAt DateTime @default(now())

  class     ClassSession @relation(fields: [classId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])

  @@index([classId])
  @@index([memberId])
  @@unique([classId, memberId])
  @@map("class_reservations")
}
